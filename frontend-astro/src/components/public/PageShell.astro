---
import { PublicNav } from "./PublicNav";
const { title, subtitle } = Astro.props;
---

<div class="sakura-bg min-h-screen">
  <div class="fixed inset-0 -z-10">
    <div class="absolute inset-0 scale-110 bg-[url('/images/sakura-mountain.png')] bg-cover bg-center opacity-[0.16] blur-[44px]"></div>
    <div class="absolute inset-0 bg-[#eef3f8]/75"></div>
    <div class="absolute inset-0 bg-rose-50/15"></div>
  </div>
  <PublicNav client:load />
  <main class="mx-auto max-w-5xl px-4 pb-20 pt-32">
    <section class="mb-10 text-center">
      <h1 class="font-serif text-4xl italic text-[#24314f]">{title}</h1>
      {subtitle && <p class="mx-auto mt-3 max-w-2xl text-sm leading-7 text-slate-500">{subtitle}</p>}
    </section>
    <slot />
  </main>
</div>
