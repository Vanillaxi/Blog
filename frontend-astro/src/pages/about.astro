---
import PublicLayout from "@/layouts/PublicLayout.astro";
import PageShell from "@/components/public/PageShell.astro";
---

<PublicLayout title="关于我 - Vanillaxi">
  <PageShell title="关于我">
    <section class="glass-card rounded-[2rem] p-8 leading-8 text-slate-600">
      <p>你好，我是 Vanillaxi，你也可以叫我 ヴァニラシ。</p>
      <p class="mt-4">这是一个安静、轻松的角落，我会在这里记录一些想法、经验。</p>
      <a
        href="https://github.com/Vanillaxi"
        target="_blank"
        rel="noopener noreferrer"
        class="mt-6 inline-flex items-center gap-2 rounded-full border border-white/55 bg-white/45 px-4 py-2 text-sm text-slate-600 shadow-sm backdrop-blur transition hover:bg-white/65 hover:text-[#24314f]"
        aria-label="GitHub"
      >
        <svg viewBox="0 0 24 24" class="h-4 w-4 fill-current" aria-hidden="true">
          <path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.11.79-.25.79-.56v-2.14c-3.2.7-3.88-1.36-3.88-1.36-.52-1.33-1.28-1.69-1.28-1.69-1.05-.72.08-.71.08-.71 1.16.08 1.77 1.19 1.77 1.19 1.03 1.76 2.7 1.25 3.36.96.1-.75.4-1.25.73-1.54-2.56-.29-5.25-1.28-5.25-5.69 0-1.26.45-2.29 1.19-3.1-.12-.29-.52-1.46.11-3.05 0 0 .97-.31 3.17 1.18A11 11 0 0 1 12 6.01c.98 0 1.96.13 2.88.39 2.2-1.49 3.17-1.18 3.17-1.18.63 1.59.23 2.76.11 3.05.74.81 1.19 1.84 1.19 3.1 0 4.42-2.7 5.4-5.27 5.68.41.36.78 1.06.78 2.14v3.16c0 .31.21.68.8.56A11.51 11.51 0 0 0 23.5 12C23.5 5.65 18.35.5 12 .5Z" />
        </svg>
        GitHub
      </a>
    </section>
  </PageShell>
</PublicLayout>
